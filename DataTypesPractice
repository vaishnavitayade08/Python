## Write a Python program to count the number of characters (character frequency) in a string.
str1 = 'google.com'
dict = {}  
for n in str1:  
    keys = dict.keys()  
    if n in keys:  
        dict[n] += 1  
    else:  
        dict[n] = 1 
print(dict) 
   
